# Copy to .env and fill in your real values.
# Nullion configuration:
NULLION_TELEGRAM_BOT_TOKEN=replace-with-your-bot-token
NULLION_TELEGRAM_OPERATOR_CHAT_ID=replace-with-your-telegram-chat-id
# Optional: enable plain text chat passthrough in the operator chat.
NULLION_TELEGRAM_CHAT_ENABLED=false

# Optional capability plugins.
# Plugins are what Nullion can do; providers are what powers the capability.
# Example: enable search/browser/workspace/media during setup.
NULLION_ENABLED_PLUGINS=search_plugin,browser_plugin,workspace_plugin,media_plugin
NULLION_PROVIDER_BINDINGS=search_plugin=builtin_search_provider,media_plugin=local_media_provider
NULLION_BROWSER_ENABLED=true
NULLION_BROWSER_BACKEND=auto
NULLION_WORKSPACE_ROOT=
NULLION_ALLOWED_ROOTS=
NULLION_BRAVE_SEARCH_API_KEY=
NULLION_GOOGLE_SEARCH_API_KEY=
NULLION_GOOGLE_SEARCH_CX=
NULLION_PERPLEXITY_API_KEY=
NULLION_AUDIO_TRANSCRIBE_COMMAND=
NULLION_IMAGE_OCR_COMMAND="tesseract {input} stdout"
NULLION_IMAGE_GENERATE_COMMAND=
NULLION_MEDIA_OPENAI_API_KEY=
NULLION_AUDIO_TRANSCRIBE_ENABLED=false
NULLION_AUDIO_TRANSCRIBE_PROVIDER=
NULLION_AUDIO_TRANSCRIBE_MODEL=
NULLION_IMAGE_OCR_ENABLED=false
NULLION_IMAGE_OCR_PROVIDER=
NULLION_IMAGE_OCR_MODEL=
NULLION_IMAGE_GENERATE_ENABLED=false
NULLION_IMAGE_GENERATE_PROVIDER=
NULLION_IMAGE_GENERATE_MODEL=
NULLION_VIDEO_INPUT_ENABLED=false
NULLION_VIDEO_INPUT_PROVIDER=
NULLION_VIDEO_INPUT_MODEL=

# Optional LLM thinking level for providers/models that support explicit reasoning controls.
NULLION_REASONING_EFFORT=medium

# Optional reference skill packs. These are instructions/workflow knowledge,
# not account access or executable plugins.
NULLION_ENABLED_SKILL_PACKS=nullion/web-research,nullion/browser-automation,nullion/files-and-docs,nullion/productivity-memory
