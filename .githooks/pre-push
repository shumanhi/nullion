#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"
while IFS= read -r git_env_name; do
  unset "$git_env_name"
done < <(git rev-parse --local-env-vars)

if [[ -x ".venv/bin/python" ]]; then
  PYTHON_CMD=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
  PYTHON_CMD="python3"
else
  PYTHON_CMD="python"
fi

TEST_REPO="${NULLION_TEST_REPO:-"$(dirname "$ROOT")/nullion-test"}"
if [[ -z "${NULLION_TEST_REPO:-}" ]]; then
  PINNED_TEST_REPO="$("$PYTHON_CMD" - <<'PY'
import json
from pathlib import Path

pin = Path.home() / ".nullion-ops" / "pinned-branches.json"
try:
    data = json.loads(pin.read_text(encoding="utf-8"))
except Exception:
    raise SystemExit(0)
repo = ((data.get("test") or {}).get("repo") or "").strip()
ref = ((data.get("test") or {}).get("ref") or "").strip()
if repo and ref:
    candidate = Path.home().parent / Path.home().name / "Projects" / "nullion-test-worktrees" / ref.split("/", 1)[-1]
    print(candidate if candidate.exists() else repo)
PY
)"
  if [[ -n "$PINNED_TEST_REPO" ]]; then
    TEST_REPO="$PINNED_TEST_REPO"
  fi
fi
TEST_PATH="$TEST_REPO/tests"

if [[ "${NULLION_SKIP_PRIVATE_TESTS:-0}" == "1" ]]; then
  echo "pre-push: skipping private coverage gate because NULLION_SKIP_PRIVATE_TESTS=1"
else
  if [[ ! -d "$TEST_PATH" ]]; then
    echo "pre-push: private test repo not found at: $TEST_REPO" >&2
    echo "pre-push: set NULLION_TEST_REPO to the private nullion-test checkout." >&2
    exit 1
  fi

  COVERAGE_FILE="$(mktemp "${TMPDIR:-/tmp}/nullion-coverage.XXXXXX")"
  export COVERAGE_FILE
  cleanup_coverage() {
    rm -f "$COVERAGE_FILE"
  }
  trap cleanup_coverage EXIT

  echo "pre-push: running private test suite with coverage; overall coverage must be at least 70%..."
  export NULLION_APP_REPO="$ROOT"
  missing_test_deps="$("$PYTHON_CMD" - <<'PY'
import importlib.util

missing = [
    package
    for module, package in (
        ("coverage", "coverage"),
        ("pytest", "pytest"),
        ("pytest_asyncio", "pytest-asyncio"),
    )
    if importlib.util.find_spec(module) is None
]
print(" ".join(missing))
PY
)"
  if [[ -n "$missing_test_deps" ]]; then
    echo "pre-push: installing missing private test runner dependencies: $missing_test_deps"
    if ! "$PYTHON_CMD" -m pip --version >/dev/null 2>&1; then
      "$PYTHON_CMD" -m ensurepip --upgrade
    fi
    "$PYTHON_CMD" -m pip install $missing_test_deps
  fi
  "$PYTHON_CMD" -m coverage erase
  NULLION_LIVE_STAGE_E2E=0 "$PYTHON_CMD" -m coverage run --source=src/nullion -m pytest -q "$TEST_PATH"
  "$PYTHON_CMD" -m coverage report --fail-under=70
fi

IMPORTANT_CHECK="$ROOT/.local-release-e2e/run-important-checks.sh"
if [[ "${NULLION_SKIP_IMPORTANT_CHECKS:-0}" == "1" ]]; then
  echo "pre-push: skipping Nullion important/e2e checks because NULLION_SKIP_IMPORTANT_CHECKS=1"
elif [[ -x "$IMPORTANT_CHECK" ]]; then
  echo "pre-push: running Nullion important/e2e checks..."
  "$IMPORTANT_CHECK"
  echo "pre-push: Nullion important/e2e checks passed."
else
  echo "pre-push: local important/e2e check harness not found; skipping $IMPORTANT_CHECK"
fi

LIVE_QA_SCRIPT="$TEST_REPO/scripts/live_stage_full_qa.py"
if [[ ! -f "$LIVE_QA_SCRIPT" ]]; then
  LIVE_QA_SCRIPT="$TEST_REPO/scripts/live_stage_full_qa_probe.py"
fi

if [[ "${NULLION_SKIP_LIVE_STAGE_QA:-0}" == "1" ]]; then
  echo "pre-push: skipping live stage QA gate because NULLION_SKIP_LIVE_STAGE_QA=1"
elif [[ ! -f "$LIVE_QA_SCRIPT" ]]; then
  echo "pre-push: live stage QA script not found in private test repo: $TEST_REPO" >&2
  exit 1
elif [[ "${NULLION_LIVE_STAGE_E2E:-}" != "1" ]]; then
  echo "pre-push: live stage QA not run; set NULLION_LIVE_STAGE_E2E=1 after stage is ready."
else
  REPORT_DIR="${NULLION_LIVE_QA_REPORT_DIR:-${HOME}/Projects/agents-worksapce/nullion-ops}"
  REPORT_PATH="${NULLION_LIVE_QA_REPORT:-${REPORT_DIR}/live-stage-full-qa-pre-push-report.json}"
  REPORT_MD_PATH="${NULLION_LIVE_QA_REPORT_MD:-${REPORT_DIR}/live-stage-full-qa-pre-push-report.md}"
  mkdir -p "$REPORT_DIR"
  echo "pre-push: running live stage full QA gate..."
  NULLION_APP_REPO="$ROOT" NULLION_LIVE_STAGE_E2E=1 "$PYTHON_CMD" "$LIVE_QA_SCRIPT" \
    --base-url "${NULLION_STAGE_BASE_URL:-http://127.0.0.1:8753}" \
    --runtime-db "${NULLION_STAGE_RUNTIME_DB:-${HOME}/.nullion-stage/runtime.db}" \
    --report "$REPORT_PATH" \
    --qa-report-md "$REPORT_MD_PATH" \
    --require-qa-tracker
  echo "pre-push: live stage full QA gate passed."
fi
