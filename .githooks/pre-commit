#!/bin/sh
set -eu

# Auto-clear stale git lock files before each commit.
# These can accumulate when sandboxed tools cannot clean up tmp objects
# on a macOS mount.
git_dir="$(git rev-parse --git-dir)"
git_local_env="$(git rev-parse --local-env-vars)"
for lock in \
    "$git_dir/HEAD.lock" \
    "$git_dir/index.lock" \
    "$git_dir/objects/maintenance.lock"; do
    [ -f "$lock" ] && rm -f "$lock" 2>/dev/null || true
done

staged_test_files="$(git diff --cached --name-only --diff-filter=ACMR -- 'tests/**' || true)"
if [ -n "$staged_test_files" ]; then
    echo "Do not commit tests/ in this repo. Put tests in the private nullion-test repo instead:" >&2
    echo "$staged_test_files" >&2
    exit 1
fi

if [ -x ".venv/bin/python" ]; then
    python_cmd=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    python_cmd="python3"
else
    python_cmd="python"
fi

app_root="$(git rev-parse --show-toplevel)"
test_repo="${NULLION_TEST_REPO:-"$(dirname "$app_root")/nullion-test"}"
test_path="$test_repo/tests"

if [ "${NULLION_SKIP_PRIVATE_TESTS:-}" = "1" ]; then
    echo "Skipping private test repo because NULLION_SKIP_PRIVATE_TESTS=1."
    exit 0
fi

if [ ! -d "$test_path" ]; then
    echo "Private test repo not found at: $test_repo" >&2
    echo "Set NULLION_TEST_REPO to the private nullion-test checkout, or clone shumanhi/nullion-test next to this repo." >&2
    exit 1
fi

coverage_file="$(mktemp "${TMPDIR:-/tmp}/nullion-coverage.XXXXXX")"
export COVERAGE_FILE="$coverage_file"
cleanup_coverage() {
    rm -f "$coverage_file"
}
trap cleanup_coverage EXIT

echo "Running private test suite before commit with coverage; overall coverage must be at least 70%..."
unset $git_local_env
export NULLION_APP_REPO="$app_root"
"$python_cmd" -m coverage erase
"$python_cmd" -m coverage run --source=src/nullion -m pytest -q "$test_path"
"$python_cmd" -m coverage report --fail-under=70
