#!/bin/sh
set -eu

# Auto-clear stale git lock files before each commit.
# These can accumulate when sandboxed tools cannot clean up tmp objects
# on a macOS mount.
git_dir="$(git rev-parse --git-dir)"
for lock in \
    "$git_dir/HEAD.lock" \
    "$git_dir/index.lock" \
    "$git_dir/objects/maintenance.lock"; do
    [ -f "$lock" ] && rm -f "$lock" 2>/dev/null || true
done

if [ -x ".venv/bin/python" ]; then
    python_cmd=".venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    python_cmd="python3"
else
    python_cmd="python"
fi

coverage_file="$(mktemp "${TMPDIR:-/tmp}/nullion-coverage.XXXXXX")"
export COVERAGE_FILE="$coverage_file"
cleanup_coverage() {
    rm -f "$coverage_file"
}
trap cleanup_coverage EXIT

echo "Running test suite before commit with coverage; overall coverage must be at least 70%..."
"$python_cmd" -m coverage erase
"$python_cmd" -m coverage run --source=src/nullion -m pytest -q
"$python_cmd" -m coverage report --fail-under=70
